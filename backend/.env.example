# ================================
# 生产环境配置示例
# 请复制此文件为 .env 并修改相应值
# ================================

# 服务器配置
NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1

# 数据库配置（必填）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password_here
DB_NAME=asg_content

# JWT配置（必填，请使用强随机字符串）
JWT_SECRET=please_change_this_to_a_random_string_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# CORS配置（必填，修改为你的前端域名）
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# ================================
# AI服务密钥（根据需要配置）
# ================================

# OpenAI API（用于内容生成等）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API（用于内容分析等）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ================================
# 外部API（可选）
# ================================

# Google自定义搜索（用于关键词研究）
GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CSE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube API
YOUTUBE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ahrefs API
AHREFS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Semrush API
SEMRUSH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ================================
# 缓存和存储（可选）
# ================================

# Redis（用于缓存和队列）
REDIS_URL=redis://localhost:6379

# MongoDB（用于文档存储）
MONGO_URL=mongodb://localhost:27017/asg_content

# ================================
# 第三方服务（可选）
# ================================

# Reddit API
REDDIT_APP_ID=
REDDIT_APP_SECRET=
REDDIT_USER_AGENT=ContentResearchSystem/1.0

# AWS S3（用于文件存储）
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# ================================
# 搜索配置
# ================================
SEARCH_ENABLE_CACHE=true
SEARCH_CACHE_TTL=300000
SEARCH_MAX_CONCURRENT=5

# ================================
# Puppeteer配置
# ================================
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# ================================
# 注意事项：
# ================================
# 1. 所有密钥和密码请使用强随机字符串
# 2. 生产环境必须修改 JWT_SECRET
# 3. 数据库密码请使用强密码
# 4. 确保 CORS_ORIGIN 只包含可信域名
# 5. API密钥请妥善保管，不要提交到版本控制
